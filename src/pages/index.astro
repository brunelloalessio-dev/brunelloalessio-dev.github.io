---
import "@/styles/global.css";

const redirectUrl = "/it/";
const redirectDelayMs = 2500;
const fallbackRefreshSeconds = 3;
const canonicalURL = new URL(redirectUrl, Astro.site);
---

<!doctype html>
<html lang="it" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,follow" />
    <meta
      name="description"
      content="Redirect alla versione italiana del portfolio di Alessio Brunello."
    />
    <meta
      http-equiv="refresh"
      content={`${fallbackRefreshSeconds};url=${redirectUrl}`}
    />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script is:inline>
      (() => {
        const saved = localStorage.getItem("theme");
        const theme = saved || "dark";
        document.documentElement.classList.remove("dark", "light");
        document.documentElement.classList.add(theme);
      })();
    </script>

    <script define:vars={{ redirectUrl, redirectDelayMs }}>
      window.setTimeout(() => {
        window.location.replace(redirectUrl);
      }, redirectDelayMs);
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <title>Alessio Brunello</title>
  </head>

  <body class="bg-bg-primary text-text-primary antialiased">
    <main
      class="relative flex min-h-screen items-center justify-center overflow-hidden px-6 py-10"
    >
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="hero-grid absolute inset-0 opacity-60"></div>
        <div
          class="absolute inset-0 bg-gradient-to-b from-bg-primary/15 via-transparent to-bg-primary"
        >
        </div>
        <div
          class="absolute left-1/2 top-[-10rem] h-[30rem] w-[30rem] -translate-x-1/2 rounded-full bg-white/8 blur-3xl"
        >
        </div>
        <div
          class="absolute left-[-4rem] top-[22%] h-56 w-56 rounded-full border border-glass-border bg-white/[0.04] blur-2xl"
        >
        </div>
        <div
          class="absolute bottom-[-8rem] right-[-5rem] h-72 w-72 rounded-full border border-glass-border bg-white/[0.03] blur-2xl"
        >
        </div>
      </div>

      <section
        class="glass-strong hover-glow relative z-10 w-full max-w-2xl overflow-hidden rounded-[2rem] px-6 py-8 shadow-2xl shadow-black/15 sm:px-10 sm:py-12"
      >
        <div
          class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/80 to-transparent"
        >
        </div>

        <div class="flex items-start justify-between gap-6">
          <div>
            <p
              class="mb-4 text-xs font-semibold uppercase tracking-[0.35em] text-accent-soft"
            >
              Frontend Tech Lead
            </p>
            <h1
              class="text-gradient text-4xl font-extrabold tracking-tight sm:text-5xl"
            >
              Alessio Brunello
            </h1>
            <p
              class="mt-4 max-w-xl text-base leading-relaxed text-text-secondary sm:text-lg"
            >
              Sto aprendo la versione italiana del portfolio con la stessa
              atmosfera che trovi nel sito.
            </p>
          </div>

          <div
            class="status-orb hidden h-14 w-14 shrink-0 items-center justify-center rounded-full border border-glass-border bg-white/[0.04] sm:flex"
          >
            <span class="status-orb__core h-4 w-4 rounded-full bg-accent"
            ></span>
          </div>
        </div>

        <div class="mt-10 flex items-center gap-4 sm:gap-5">
          <div
            class="relative h-12 w-12 shrink-0 rounded-full border border-accent/15 bg-white/[0.03]"
          >
            <div
              class="loader-ring absolute inset-1 rounded-full border-2 border-transparent border-t-accent border-r-accent/35"
            >
            </div>
            <div class="absolute inset-[0.8rem] rounded-full bg-accent/10">
            </div>
          </div>

          <div class="min-w-0 flex-1">
            <div
              class="flex items-center justify-between gap-4 text-sm font-medium text-text-primary"
            >
              <span>Reindirizzamento in corso</span>
              <span class="text-text-secondary">/it/</span>
            </div>
            <div class="mt-3 h-px overflow-hidden rounded-full bg-white/10">
              <div class="progress-line h-full w-full"></div>
            </div>
          </div>
        </div>

        <p class="mt-8 text-sm leading-relaxed text-text-secondary">
          Se non vieni reindirizzato automaticamente, continua da
          <a
            class="ml-1 font-semibold text-text-primary underline decoration-glass-border underline-offset-4"
            href={redirectUrl}
          >
            qui
          </a>.
        </p>
      </section>
    </main>
  </body>
</html>

<style>
  .hero-grid {
    background-image:
      linear-gradient(to right, var(--color-glass-border) 1px, transparent 1px),
      linear-gradient(to bottom, var(--color-glass-border) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(circle at center, black 28%, transparent 82%);
  }

  .status-orb {
    animation: float 4s ease-in-out infinite;
  }

  .status-orb__core {
    box-shadow: 0 0 24px rgba(255, 255, 255, 0.45);
    animation: pulse 1.8s ease-in-out infinite;
  }

  .loader-ring {
    animation: spin 1.1s linear infinite;
  }

  .progress-line {
    transform-origin: left center;
    animation: loadBar 2500ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.22) 0%,
      rgba(255, 255, 255, 0.95) 100%
    );
  }

  html.light .progress-line {
    background: linear-gradient(
      90deg,
      rgba(9, 9, 11, 0.18) 0%,
      rgba(9, 9, 11, 0.92) 100%
    );
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.55;
      transform: scale(0.92);
    }

    50% {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-8px);
    }
  }

  @keyframes loadBar {
    from {
      transform: scaleX(0.16);
      opacity: 0.35;
    }

    to {
      transform: scaleX(1);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .status-orb,
    .status-orb__core,
    .loader-ring,
    .progress-line {
      animation-duration: 0.01ms;
      animation-iteration-count: 1;
    }
  }
</style>
