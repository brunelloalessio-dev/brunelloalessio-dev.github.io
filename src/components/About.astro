---
import type { Locale } from "@/i18n/utils";
import { t } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);

const stats = [
  { value: i18n.about.stats.years, label: i18n.about.stats.years_label, color: "text-accent" },
  { value: i18n.about.stats.role, label: i18n.about.stats.role_label, color: "text-accent" },
];
---

<section id="about" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="fade-in mb-16 text-center">
      <h2 class="text-gradient mb-4 text-3xl font-bold sm:text-4xl">{i18n.about.title}</h2>
      <div class="mx-auto h-1 w-20 rounded-full bg-accent-soft"></div>
    </div>

    <!-- Content card -->
    <div class="fade-in glass hover-glow mx-auto max-w-4xl rounded-2xl p-8 sm:p-12">
      <p class="mb-6 text-base leading-relaxed text-text-secondary sm:text-lg">
        {i18n.about.description}
      </p>
      <p class="mb-10 text-base leading-relaxed text-text-secondary sm:text-lg">
        {i18n.about.description2}
      </p>

      <!-- Stats -->
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 max-w-2xl mx-auto">
        {stats.map((stat) => (
          <div class="glass rounded-xl p-6 text-center">
            <div class={`mb-2 text-3xl font-extrabold ${stat.color}`}>
              {stat.value}
            </div>
            <div class="text-sm text-text-secondary">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
