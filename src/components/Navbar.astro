---
import type { Locale } from "@/i18n/utils";
import { t, getAlternateLocale, getLocalePath } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
const altLocale = getAlternateLocale(locale);
const altPath = getLocalePath(altLocale);
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between md:h-20">
      <!-- Logo -->
      <a
        href={`/${locale}/`}
        class="text-gradient text-xl font-extrabold tracking-tight md:text-2xl"
      >
        AB
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden items-center gap-8 md:flex">
        <a href="#about" class="nav-link text-sm font-medium text-text-secondary transition-colors hover:text-text-primary">{i18n.nav.about}</a>
        <a href="#skills" class="nav-link text-sm font-medium text-text-secondary transition-colors hover:text-text-primary">{i18n.nav.skills}</a>
        <a href="#experience" class="nav-link text-sm font-medium text-text-secondary transition-colors hover:text-text-primary">{i18n.nav.experience}</a>
        <a href="#certifications" class="nav-link text-sm font-medium text-text-secondary transition-colors hover:text-text-primary">{i18n.nav.certifications}</a>
        <a href="#contact" class="nav-link text-sm font-medium text-text-secondary transition-colors hover:text-text-primary">{i18n.nav.contact}</a>
      </div>

      <!-- Right side: Theme toggle + Lang switch + GitHub + Mobile menu -->
      <div class="flex items-center gap-3">
        <!-- Theme Toggle -->
        <button
          id="theme-toggle"
          class="text-text-secondary transition-colors hover:text-text-primary"
          aria-label="Toggle theme"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg id="icon-sun" class="hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg id="icon-moon" class="hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/>
          </svg>
        </button>

        <!-- Language Switch -->
        <a
          href={altPath}
          class="glass hover-glow rounded-lg px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-text-secondary transition-all hover:text-text-primary"
        >
          {altLocale.toUpperCase()}
        </a>

        <!-- GitHub -->
        <a
          href="https://github.com/brunelloalessio-dev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-secondary transition-colors hover:text-text-primary"
          aria-label="GitHub"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="text-text-secondary transition-colors hover:text-text-primary md:hidden"
          aria-label="Menu"
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="glass-strong fixed inset-0 top-16 -translate-x-full opacity-0 transition-all duration-300 md:hidden"
  >
    <div class="flex flex-col gap-6 p-8">
      <a href="#about" class="mobile-nav-link text-lg font-medium text-text-secondary transition-colors hover:text-text-primary">{i18n.nav.about}</a>
      <a href="#skills" class="mobile-nav-link text-lg font-medium text-text-secondary transition-colors hover:text-text-primary">{i18n.nav.skills}</a>
      <a href="#experience" class="mobile-nav-link text-lg font-medium text-text-secondary transition-colors hover:text-text-primary">{i18n.nav.experience}</a>
      <a href="#certifications" class="mobile-nav-link text-lg font-medium text-text-secondary transition-colors hover:text-text-primary">{i18n.nav.certifications}</a>
      <a href="#contact" class="mobile-nav-link text-lg font-medium text-text-secondary transition-colors hover:text-text-primary">{i18n.nav.contact}</a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const themeToggle = document.getElementById("theme-toggle");
  const iconSun = document.getElementById("icon-sun");
  const iconMoon = document.getElementById("icon-moon");
  let isOpen = false;

  // Theme toggle
  function updateThemeIcons() {
    const isDark = document.documentElement.classList.contains("dark");
    iconSun?.classList.toggle("hidden", !isDark);
    iconMoon?.classList.toggle("hidden", isDark);
  }

  updateThemeIcons();

  themeToggle?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.contains("dark");
    const newTheme = isDark ? "light" : "dark";
    document.documentElement.classList.remove("dark", "light");
    document.documentElement.classList.add(newTheme);
    localStorage.setItem("theme", newTheme);
    updateThemeIcons();
    // Dispatch event for particles
    window.dispatchEvent(new CustomEvent("themechange", { detail: newTheme }));
  });

  // Glassmorphism on scroll
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      navbar?.classList.add("glass");
    } else {
      navbar?.classList.remove("glass");
    }
  });

  // Mobile menu toggle
  mobileMenuBtn?.addEventListener("click", () => {
    isOpen = !isOpen;
    if (isOpen) {
      mobileMenu?.classList.add("nav-open");
    } else {
      mobileMenu?.classList.remove("nav-open");
    }
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      isOpen = false;
      mobileMenu?.classList.remove("nav-open");
    });
  });
</script>
