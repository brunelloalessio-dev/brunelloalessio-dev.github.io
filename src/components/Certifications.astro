---
import type { Locale } from "@/i18n/utils";
import { t } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
const linkedinProfileUrl = i18n.contact.linkedin.url;

const issuerLogoMap: Record<string, { src: string; alt: string }> = {
  Anthropic: {
    src: "/logos/issuers/anthropic.svg",
    alt: "Anthropic logo",
  },
  Google: {
    src: "/logos/issuers/google.svg",
    alt: "Google logo",
  },
  Udemy: {
    src: "/logos/issuers/udemy.svg",
    alt: "Udemy logo",
  },
};
---

<section id="certifications" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="fade-in mb-16 text-center">
      <h2 class="text-gradient mb-4 text-3xl font-bold sm:text-4xl">
        {i18n.certifications.title}
      </h2>
      <p class="text-text-secondary">{i18n.certifications.subtitle}</p>
      <div class="mt-6 flex justify-center">
        <a
          href={linkedinProfileUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-accent/30 px-4 py-2 text-sm font-semibold text-accent transition-colors hover:border-accent/60 hover:bg-accent/10"
        >
          {i18n.certifications.view_all}
          <svg
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 6H18m0 0v4.5M18 6l-7.5 7.5"></path>
          </svg>
        </a>
      </div>
      <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent-soft"></div>
    </div>

    <!-- Certifications grid -->
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        i18n.certifications.items.map((cert) => {
          const issuerLogo = issuerLogoMap[cert.issuer];

          return (
            <article class="fade-in glass hover-glow flex h-full flex-col rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
              <div class="mb-4 flex items-start justify-between gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-black/5 bg-white p-2">
                  {issuerLogo ? (
                    <img
                      src={issuerLogo.src}
                      alt={issuerLogo.alt}
                      class="h-full w-full object-contain"
                      loading="lazy"
                    />
                  ) : (
                    <span class="text-sm font-semibold text-[#191919]">
                      {cert.issuer.charAt(0)}
                    </span>
                  )}
                </div>
                <span class="rounded-full border border-white/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-text-secondary">
                  {cert.issuedAt}
                </span>
              </div>

              <div class="mb-3">
                <span class="inline-flex rounded-full bg-accent/10 px-3 py-1 text-xs font-semibold text-accent">
                  {cert.issuer}
                </span>
              </div>

              <h3 class="mb-3 text-base font-semibold leading-snug text-text-primary">
                {cert.name}
              </h3>
              <p class="text-sm leading-relaxed text-text-secondary">
                {cert.description}
              </p>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
