---
import type { Locale } from "@/i18n/utils";
import { t } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i18n = t(locale);
---

<section id="contact" class="relative py-24 sm:py-32">
  <!-- Background gradient mesh -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute left-1/4 top-1/4 h-96 w-96 rounded-full bg-accent/5 blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 h-96 w-96 rounded-full bg-accent/3 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="fade-in mb-16 text-center">
      <h2 class="text-gradient mb-4 text-3xl font-bold sm:text-4xl">{i18n.contact.title}</h2>
      <p class="text-text-secondary">{i18n.contact.subtitle}</p>
      <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-accent-soft"></div>
    </div>

    <!-- Contact cards -->
    <div class="fade-in mx-auto grid max-w-4xl gap-6 sm:grid-cols-3">
      <!-- Email -->
      <button
        id="copy-email"
        class="glass hover-glow group flex flex-col items-center rounded-2xl p-8 text-center transition-all hover:scale-105"
        data-email={i18n.contact.email.value}
      >
        <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-accent/10 transition-colors group-hover:bg-accent/20">
          <svg class="h-8 w-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
        </div>
        <h3 class="mb-1 text-lg font-semibold text-text-primary">{i18n.contact.email.label}</h3>
        <p class="mb-3 text-sm text-text-secondary">{i18n.contact.email.value}</p>
        <span id="copy-email-text" class="text-xs font-medium text-accent">{i18n.contact.email.cta}</span>
      </button>

      <!-- LinkedIn -->
      <a
        href={i18n.contact.linkedin.url}
        target="_blank"
        rel="noopener noreferrer"
        class="glass hover-glow group flex flex-col items-center rounded-2xl p-8 text-center transition-all hover:scale-105"
      >
        <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-accent/10 transition-colors group-hover:bg-accent/20">
          <svg class="h-8 w-8 text-accent" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <h3 class="mb-1 text-lg font-semibold text-text-primary">{i18n.contact.linkedin.label}</h3>
        <p class="mb-3 text-sm text-text-secondary">{i18n.contact.linkedin.value}</p>
        <span class="text-xs font-medium text-accent">{i18n.contact.linkedin.cta} →</span>
      </a>

      <!-- GitHub -->
      <a
        href={i18n.contact.github.url}
        target="_blank"
        rel="noopener noreferrer"
        class="glass hover-glow group flex flex-col items-center rounded-2xl p-8 text-center transition-all hover:scale-105"
      >
        <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-accent/10 transition-colors group-hover:bg-accent/20">
          <svg class="h-8 w-8 text-accent" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </div>
        <h3 class="mb-1 text-lg font-semibold text-text-primary">{i18n.contact.github.label}</h3>
        <p class="mb-3 text-sm text-text-secondary">{i18n.contact.github.value}</p>
        <span class="text-xs font-medium text-accent">{i18n.contact.github.cta} →</span>
      </a>
    </div>
  </div>
</section>

<script>
  const copyBtn = document.getElementById("copy-email");
  const copyText = document.getElementById("copy-email-text");
  const originalText = copyText?.textContent;

  copyBtn?.addEventListener("click", async () => {
    const email = copyBtn.getAttribute("data-email");
    if (email && navigator.clipboard) {
      await navigator.clipboard.writeText(email);
      if (copyText) {
        copyText.textContent = "✓ Copied!";
        setTimeout(() => {
          copyText.textContent = originalText || "";
        }, 2000);
      }
    }
  });
</script>
